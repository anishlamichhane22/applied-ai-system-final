# Environment Variables for PawPal
# Copy this file to .env and fill in your actual values

# Anthropic API Key - Primary AI service (paid)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter API Key - Free alternative AI service
# Get your FREE key from: https://openrouter.ai/
# Sign up and get API key - has generous free tier
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO